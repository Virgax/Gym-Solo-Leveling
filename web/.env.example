# Cloud sync (Supabase). Leave blank to run fully local-first (no login).
# For local dev, copy to `.env.local` and fill in. In CI these come from
# GitHub → Settings → Secrets and variables → Actions → Variables.
# The anon key is public/safe to ship in the client bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
