# Railway injects DATABASE_URL and PORT automatically when you attach Postgres.
# You set these three:
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
JWT_SECRET=generate-a-long-random-string
CORS_ORIGIN=https://virgax.github.io

# Only if you use an EXTERNAL Postgres URL (not Railway's internal one):
# PGSSL=true
